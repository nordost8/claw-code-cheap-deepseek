# Claw Code — змінні середовища (Rust CLI: rust/target/release/claw)
#
# --- DeepSeek (OpenAI-сумісний API) ---
# Не задавай ANTHROPIC_* якщо хочеш лише DeepSeek. Модель за замовчуванням
# стане deepseek-chat, якщо є DEEPSEEK_API_KEY і немає Anthropic-ключа.
#
# export DEEPSEEK_API_KEY="sk-..."
# optional: export DEEPSEEK_API_BASE="https://api.deepseek.com/v1"
# optional: export DEEPSEEK_MODEL="deepseek-chat"   # або deepseek-reasoner тощо
#
# Запуск:
#   cd rust && ./target/release/claw
#   ./target/release/claw --model deepseek-chat prompt "привіт"
#
# --- Anthropic (Claude) ---
# export ANTHROPIC_API_KEY="sk-ant-..."
# optional: export ANTHROPIC_BASE_URL=https://api.anthropic.com
#
# --- OpenAI / xAI (Grok) ---
# export OPENAI_API_KEY=...  # + --model gpt-...
# export XAI_API_KEY=...     # + --model grok / grok-3 ...
#
# Автокомпакція довгої історії
# export CLAUDE_CODE_AUTO_COMPACT_INPUT_TOKENS=50000
